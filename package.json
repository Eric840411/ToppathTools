{
  "name": "toppath-tools",
  "private": true,
  "version": "3.26.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm run dev:stop && tsx --watch server/index.ts",
    "dev:all": "npm run dev:stop && concurrently -n \"API,Web\" -c \"cyan,magenta\" \"tsx --watch server/index.ts\" \"vite\"",
    "dev:internal": "npm run dev:stop:internal && concurrently -n \"API-dev,Web-dev\" -c \"yellow,green\" \"tsx --watch server/index.dev.ts\" \"vite --config vite.dev.config.ts\"",
    "dev:stop": "powershell -Command \"foreach ($p in @(3000,5173)) { $id = (netstat -aon | sls (':'+$p+'\\s') | sls LISTENING | %{($_ -split '\\s+')[-1]} | select -f 1); if($id){ taskkill /PID $id /F } }; exit 0\"",
    "dev:stop:internal": "powershell -Command \"foreach ($p in @(3001,5174)) { $id = (netstat -aon | sls (':'+$p+'\\s') | sls LISTENING | %{($_ -split '\\s+')[-1]} | select -f 1); if($id){ taskkill /PID $id /F } }; exit 0\"",
    "start:all": "npm run dev:stop && concurrently -n \"API,Web\" -c \"cyan,magenta\" \"tsx server/index.ts\" \"vite\"",
    "build": "tsc -b && npm run build:server && vite build",
    "build:server": "node scripts/build-server.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "node dist-server/server/index.js",
    "start:worker": "node dist-server/server/worker.js",
    "start": "npm run build && node dist-server/server/index.js",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:restart": "npm run build && pm2 restart toppath-server toppath-worker",
    "pm2:worker:restart": "pm2 restart toppath-worker",
    "pm2:stop": "pm2 stop toppath-server toppath-worker toppath-tunnel",
    "pm2:delete": "pm2 delete toppath-server toppath-worker toppath-tunnel",
    "pm2:logs": "pm2 logs toppath-server",
    "pm2:worker:logs": "pm2 logs toppath-worker",
    "pm2:tunnel:logs": "pm2 logs toppath-tunnel",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "audify": "^1.10.1",
    "better-sqlite3": "^12.8.0",
    "bottleneck": "^2.19.5",
    "cors": "^2.8.6",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-record-lpcm16": "^1.0.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
