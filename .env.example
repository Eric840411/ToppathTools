PORT=3000

# Jira（Base URL 與專案設定由管理員設定，個人憑證由使用者在前端自行填入）
VITE_JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_PROJECT_ID=
JIRA_ISSUE_TYPE_ID=
JIRA_TRANSITION_ID=
JIRA_VERIFIER_FIELD_ID=
JIRA_DIFFICULTY_FIELD_ID=

# 團隊成員 accountId（逗號分隔，名字由系統從 Jira API 動態取得）
TEAM_ACCOUNT_IDS=

# Lark
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BASE_URL=https://open.larksuite.com
LARK_WEBHOOK_ID=

# Lark Bitable（TestCase）
# 設定 FOLDER_TOKEN 後，每次生成會自動在該資料夾建立新的 Bitable（推薦）
LARK_TESTCASE_FOLDER_TOKEN=
# 以下為舊版固定表格設定（FOLDER_TOKEN 存在時不使用）
LARK_TESTCASE_APP_TOKEN=
LARK_TESTCASE_TABLE_ID=
LARK_TESTCASE_URL=

# Lark Bitable（OSM 版本記錄）
LARK_OSM_APP_TOKEN=
LARK_OSM_TABLE_ID=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Google Sheets（用於 Jira 資料來源，需在 Google Cloud Console 開啟 Sheets API）
GOOGLE_API_KEY=
# Google Service Account（用於回寫 Jira Key 到 Google Sheet，需建立 Service Account 並分享試算表給它）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Gmail OAuth2（Refresh Token 方式，不會過期）
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# 舊版 Access Token（備用，若上方三項未填則嘗試直接使用）
GMAIL_ACCESS_TOKEN=
GMAIL_QUERY=from:SNSoft-OSM subject:"Image Recon Version Check Report" in:inbox

# OSM Backend
OSM_BASE_URL=

# OSM 渠道清單（逗號分隔）
OSM_CHANNELS=

OSM_CHANNEL_CP_ID=
OSM_CHANNEL_CP_USERNAME=
OSM_CHANNEL_CP_PASSWORD=
OSM_CHANNEL_CP_ORIGIN=

OSM_CHANNEL_WF_ID=
OSM_CHANNEL_WF_USERNAME=
OSM_CHANNEL_WF_PASSWORD=
OSM_CHANNEL_WF_ORIGIN=

# ... 依此類推，每個渠道加一組 OSM_CHANNEL_xxx_ID/USERNAME/PASSWORD/ORIGIN

# LuckyLink Backend（版本查詢，無帳密則跳過登入直接查詢）
LUCKYLINK_BASE_URL=
LUCKYLINK_USERNAME=
LUCKYLINK_PASSWORD=
LUCKYLINK_ORIGIN=

# 管理員 PIN（用於帳號刪除操作，留空則停用管理員功能）
ADMIN_PIN=

# 阿里雲 SLS（AutoSpin 機台錯誤日誌查詢）
SLS_KEY_ID=
SLS_KEY_SECRET=
SLS_ENDPOINT=ap-southeast-1.log.aliyuncs.com
SLS_PROJECTS=liveslots-luckylinkmml-test-logs,liveslots-luckylinkg2s-test-logs,liveslots-luckylinkmml-cms-logs,liveslots-luckylinkg2s-cms-logs
